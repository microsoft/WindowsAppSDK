<?xml version="1.0" encoding="utf-8"?>
<!--
    Version.Dependencies.props - Rewritten for Central Package Management (CPM).
    
    Previously: Generated from Version.Details.xml + Version.Dependencies.xml via regex at MSBuild time.
    Now: Hardcoded versions matching Directory.Packages.props (CPM).
    
    These MSBuild properties are consumed by .vcxproj files and packages.config for NuGet restore.
    Property names follow the Maestro convention: PackageName.Replace(".", "") + "PackageVersion" or "Version".

    TODO: When all .vcxproj projects are migrated to SDK-style, this file can be deleted entirely.
    Version source of truth is now Directory.Packages.props (CPM).
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <!-- ================================================================
         Internal WinAppSDK packages (from Version.Details.xml ProductDependencies)
         Versions match Directory.Packages.props internal package entries.
         In mono-build, these are overridden by WindowsAppSDKVersionPinned.
         ================================================================ -->
    <MicrosoftFrameworkUdkPackageVersion>2.0.0-experimental-27300.1857.260302-0806.0</MicrosoftFrameworkUdkPackageVersion>
    <MicrosoftProjectReunionInteractiveExperiencesTransportPackagePackageVersion>2.0.0-experimental-27300.1857.260302-0806.0</MicrosoftProjectReunionInteractiveExperiencesTransportPackagePackageVersion>
    <MicrosoftWindowsAppSDKAppLicensingInternalTransportPackagePackageVersion>1.7.0-main.20241009.0</MicrosoftWindowsAppSDKAppLicensingInternalTransportPackagePackageVersion>
    <MicrosoftWindowsAppSDKBasePackageVersion>2.0.260323000-dev.experimental9</MicrosoftWindowsAppSDKBasePackageVersion>
    <MicrosoftWindowsAppSDKInteractiveExperiencesPackageVersion>2.0.10-experimental</MicrosoftWindowsAppSDKInteractiveExperiencesPackageVersion>

    <!-- CsWinRT dependency metadata (from Version.Details.xml ToolsetDependencies) -->
    <CsWinRTDependencyDotNetCoreRuntimePackageVersion>6.0.33</CsWinRTDependencyDotNetCoreRuntimePackageVersion>
    <CsWinRTDependencyDotNetCoreSdkPackageVersion>6.0.425</CsWinRTDependencyDotNetCoreSdkPackageVersion>
    <CsWinRTDependencyWindowsSdkVersionSuffixPackageVersion>38</CsWinRTDependencyWindowsSdkVersionSuffixPackageVersion>

    <!-- WindowsAppSDK.Version (pipeline version metadata) -->
    <MicrosoftWindowsAppSDKVersionPackageVersion>1.8.0</MicrosoftWindowsAppSDKVersionPackageVersion>

    <!-- CsWinRT -->
    <MicrosoftWindowsCsWinRTPackageVersion>2.1.1</MicrosoftWindowsCsWinRTPackageVersion>

    <!-- ================================================================
         Toolset packages (from Version.Dependencies.xml)
         Versions match Directory.Packages.props external package entries.
         ================================================================ -->
    <MicrosoftBuildTasksGitVersion>1.1.1</MicrosoftBuildTasksGitVersion>
    <MicrosoftSourceLinkCommonVersion>1.1.1</MicrosoftSourceLinkCommonVersion>
    <MicrosoftSourceLinkGitHubVersion>1.1.1</MicrosoftSourceLinkGitHubVersion>
    <MicrosoftTaefVersion>10.95.240918004</MicrosoftTaefVersion>
    <MicrosoftTelemetryInboxNativeVersion>10.0.19041.1-191206-1406.vb-release.x86fre</MicrosoftTelemetryInboxNativeVersion>
    <MicrosoftWebWebView2Version>1.0.961.33</MicrosoftWebWebView2Version>
    <MicrosoftWindowsAppSDKProtobufVersion>3.21.12</MicrosoftWindowsAppSDKProtobufVersion>
    <MicrosoftWindowsAppSDKVersion>1.6.250408002</MicrosoftWindowsAppSDKVersion>
    <MicrosoftWindowsCppWinRTVersion>2.0.230706.1</MicrosoftWindowsCppWinRTVersion>
    <MicrosoftWindowsImplementationLibraryVersion>1.0.240803.1</MicrosoftWindowsImplementationLibraryVersion>
    <MicrosoftWindowsSDKBuildToolsMSIXVersion>1.7.20250829.1</MicrosoftWindowsSDKBuildToolsMSIXVersion>
    <MicrosoftWindowsSDKBuildToolsVersion>10.0.26100.4654</MicrosoftWindowsSDKBuildToolsVersion>
  </PropertyGroup>
</Project>