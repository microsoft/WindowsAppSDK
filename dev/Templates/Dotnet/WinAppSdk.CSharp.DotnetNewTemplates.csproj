<Project Sdk="Microsoft.NET.Sdk">
  <!--
      The declarative list of project templates and their per-template
      metadata lives in ..\templates.props. This csproj only encodes the
      generic packaging rules.
  -->
  <Import Project="..\templates.props" />

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>false</ImplicitUsings>
    <Nullable>disable</Nullable>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IsPackable>true</IsPackable>
    <PackageType>Template</PackageType>
    <PackageId>Microsoft.WindowsAppSDK.WinUI.CSharp.Templates</PackageId>
    <Version>0.0.5-alpha</Version>
    <Title>WinUI 3 C# Templates</Title>
    <Authors>Microsoft</Authors>
    <Company>Microsoft</Company>
    <Description>Official WinUI 3 project and item templates. Install this pack to use dotnet new for different types of apps, class libraries, unit tests and common WinUI controls.</Description>
    <PackageTags>windows;winappsdk;winui;winui3;desktop;dotnet-new;templates;csharp</PackageTags>
    <PackageProjectUrl>https://learn.microsoft.com/windows/apps/windows-app-sdk/</PackageProjectUrl>
    <RepositoryUrl>https://github.com/microsoft/WindowsAppSDK</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Copyright>© Microsoft Corporation. All rights reserved.</Copyright>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageReleaseNotes>See https://github.com/microsoft/WindowsAppSDK/releases for release notes.</PackageReleaseNotes>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <NoWarn>$(NoWarn);NU5128;CS2008</NoWarn>
    <!--
        MSB5029 ("wildcard enumerates all files on the drive") is a static
        safety check that fires before target-level batching resolves
        %(ProjectTemplate.SourceDir) inside _ExpandProjectTemplatePackItems.
        Demote it to an informational message; the runtime expansion produces
        fully-qualified paths per template (verified via DiagTemplates).
    -->
    <MSBuildWarningsAsMessages>$(MSBuildWarningsAsMessages);MSB5029</MSBuildWarningsAsMessages>
    <PackageOutputPath Condition="'$(PackageOutputPath)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\..\localpackages'))</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="README.md" />
  </ItemGroup>

  <!-- Shared .gitignore for all project templates -->
  <PropertyGroup>
    <_GitignoreSource>templates\gitignore.txt</_GitignoreSource>
  </PropertyGroup>

  <!--
      ExpandProjectTemplatePackItems: an inline C# MSBuild task that takes the
      declarative @(ProjectTemplate) list (declared in ..\templates.props) and
      emits the concrete files-to-pack along with their PackagePath metadata.

      Why a task instead of a batched <ItemGroup>:
        MSBuild applies a static MSB5029 ("wildcard enumerates whole drive")
        check to Include attributes that contain wildcards. The check runs
        BEFORE target-level batching or in-target properties resolve, so any
        Include of the form "%(ProjectTemplate.SourceDir)\**\*.*" is rejected
        even though batching would produce fully-qualified paths at run time.
        A real MSBuild task is opaque to that static check; the enumeration
        happens via System.IO at task execution time.
  -->
  <UsingTask TaskName="ExpandProjectTemplatePackItems"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Templates ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
      <GitignoreSource ParameterType="System.String" Required="false" />
      <ExpandedItems ParameterType="Microsoft.Build.Framework.ITaskItem[]" Output="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Using Namespace="System.Collections.Generic" />
      <Using Namespace="Microsoft.Build.Framework" />
      <Using Namespace="Microsoft.Build.Utilities" />
      <Code Type="Fragment" Language="cs">
<![CDATA[
var output = new List<ITaskItem>();
var commonExcludeNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { "bin", "obj" };

void Emit(string sourcePath, string packagePath)
{
    var item = new TaskItem(sourcePath);
    item.SetMetadata("Pack", "true");
    item.SetMetadata("PackagePath", packagePath);
    output.Add(item);
}

foreach (var t in Templates)
{
    string id = t.ItemSpec;
    string srcDir = t.GetMetadata("SourceDir");
    string configDir = t.GetMetadata("DotnetConfigDir");
    string baseName = t.GetMetadata("BaseName");
    string renameFrom = t.GetMetadata("RenameManifestFrom");
    string contentRoot = "content/" + id;

    // 1. Source tree, excluding bin/obj, the VSIX-only sidecar files, and (if set) the
    //    Source-named manifest (which is re-emitted below under the canonical name).
    if (Directory.Exists(srcDir))
    {
        var perTemplateExclude = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            baseName + ".csproj",
            baseName + ".ico",
            baseName + ".png",
            baseName + ".vstemplate",
        };
        if (!string.IsNullOrEmpty(renameFrom)) { perTemplateExclude.Add(renameFrom); }

        foreach (var file in Directory.EnumerateFiles(srcDir, "*", SearchOption.AllDirectories))
        {
            string rel = file.Substring(srcDir.Length).TrimStart('\\', '/');
            // Skip any file under a top-level bin\ or obj\ directory.
            int sep = rel.IndexOfAny(new[] { '\\', '/' });
            string topDir = sep < 0 ? string.Empty : rel.Substring(0, sep);
            if (commonExcludeNames.Contains(topDir)) { continue; }
            // Skip sidecar files in the template root.
            if (sep < 0 && perTemplateExclude.Contains(rel)) { continue; }

            Emit(file, contentRoot + "/" + rel.Replace('\\', '/'));
        }
    }

    // 2. Source-named manifest -> reserved Package.appxmanifest, if requested.
    if (!string.IsNullOrEmpty(renameFrom))
    {
        string manifestPath = Path.Combine(srcDir, renameFrom);
        if (File.Exists(manifestPath))
        {
            Emit(manifestPath, contentRoot + "/Package.appxmanifest");
        }
    }

    // 3. dotnet-new template configuration.
    string configRoot = Path.Combine(configDir, ".template.config");
    if (Directory.Exists(configRoot))
    {
        foreach (var file in Directory.EnumerateFiles(configRoot, "*", SearchOption.AllDirectories))
        {
            string rel = file.Substring(configDir.Length).TrimStart('\\', '/');
            Emit(file, contentRoot + "/" + rel.Replace('\\', '/'));
        }
    }

    // 4. Optional companion assets (Agents.md, instructions/**).
    string agentsPath = Path.Combine(configDir, "Agents.md");
    if (File.Exists(agentsPath))
    {
        Emit(agentsPath, contentRoot + "/AGENTS.md");
    }
    string instructionsDir = Path.Combine(configDir, "instructions");
    if (Directory.Exists(instructionsDir))
    {
        foreach (var file in Directory.EnumerateFiles(instructionsDir, "*", SearchOption.AllDirectories))
        {
            string rel = file.Substring(instructionsDir.Length).TrimStart('\\', '/');
            Emit(file, contentRoot + "/.github/instructions/" + rel.Replace('\\', '/'));
        }
    }

    // 5. Shared .gitignore (one copy per template).
    if (!string.IsNullOrEmpty(GitignoreSource) && File.Exists(GitignoreSource))
    {
        Emit(GitignoreSource, contentRoot + "/gitignore.txt");
    }
}

ExpandedItems = output.ToArray();
]]>
      </Code>
    </Task>
  </UsingTask>

  <Target Name="_ExpandProjectTemplatePackItems"
          BeforeTargets="_GetPackageFiles;GenerateNuspec">
    <!--
        Pack the project templates declared as @(ProjectTemplate). Each one
        gets the shared .gitignore copy. @(VsixOnlyProjectTemplate) is
        intentionally not consumed here.
    -->
    <ExpandProjectTemplatePackItems Templates="@(ProjectTemplate)"
                                    GitignoreSource="$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)$(_GitignoreSource)'))">
      <Output TaskParameter="ExpandedItems" ItemName="None" />
    </ExpandProjectTemplatePackItems>

    <!--
        Pack the item templates declared as @(ItemTemplate). Item templates
        don't ship a .gitignore (their content is added into an existing
        project, which already has one).
    -->
    <ExpandProjectTemplatePackItems Templates="@(ItemTemplate)">
      <Output TaskParameter="ExpandedItems" ItemName="None" />
    </ExpandProjectTemplatePackItems>
  </Target>
</Project>
