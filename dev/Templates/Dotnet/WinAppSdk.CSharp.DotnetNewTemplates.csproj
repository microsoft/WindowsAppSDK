          Pack="true"
          PackagePath="content/winui.blankapp/Package.appxmanifest" />
    <None Include="$(_GitignoreSource)"
          Pack="true"
          PackagePath="content/winui.blankapp/gitignore.txt" />
  </ItemGroup>

