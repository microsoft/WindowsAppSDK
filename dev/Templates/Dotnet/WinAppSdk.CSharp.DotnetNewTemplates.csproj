          Pack="true"
          PackagePath="content/winui.blankapp/AGENTS.md" />
    <None Include="templates\single-project\instructions\**\*.*"
          Pack="true"
          PackagePath="content/winui.blankapp/.github/instructions/%(RecursiveDir)%(Filename)%(Extension)" />
    <None Include="..\Source\ProjectTemplates\Desktop\CSharp\SingleProjectPackagedApp\**\*.*"
          Exclude="..\Source\ProjectTemplates\Desktop\CSharp\SingleProjectPackagedApp\bin\**;..\Source\ProjectTemplates\Desktop\CSharp\SingleProjectPackagedApp\obj\**;..\Source\ProjectTemplates\Desktop\CSharp\SingleProjectPackagedApp\Package-managed.appxmanifest;..\Source\ProjectTemplates\Desktop\CSharp\SingleProjectPackagedApp\WinUI.Desktop.Cs.SingleProjectPackagedApp.csproj;..\Source\ProjectTemplates\Desktop\CSharp\SingleProjectPackagedApp\WinUI.Desktop.Cs.SingleProjectPackagedApp.ico;..\Source\ProjectTemplates\Desktop\CSharp\SingleProjectPackagedApp\WinUI.Desktop.Cs.SingleProjectPackagedApp.png;..\Source\ProjectTemplates\Desktop\CSharp\SingleProjectPackagedApp\WinUI.Desktop.Cs.SingleProjectPackagedApp.vstemplate"
