<?xml version="1.0" encoding="utf-8"?>
<!--
  Standalone NuGet configuration for the local VSIX build.
  This file is passed explicitly to MSBuild via /p:RestoreConfigFile.
  It adds nuget.org so that public packages (Microsoft.WindowsAppSDK,
  Microsoft.VisualStudio.SDK, etc.) can be restored without Microsoft
  internal feed access.
-->
<configuration>
  <config>
    <!-- Use a local packages folder so we don't pollute the global cache -->
    <add key="globalPackagesFolder" value="Packages" />
  </config>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!--
      If you have access to the Microsoft internal feed, uncomment below:
      <add key="ProjectReunion internal" value="https://microsoft.pkgs.visualstudio.com/ProjectReunion/_packaging/Project.Reunion.nuget.internal/nuget/v3/index.json" />
    -->
  </packageSources>
  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
