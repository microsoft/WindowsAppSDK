{
  "weights": {
    "reactions": 0.3,
    "age": 0.3,
    "comments": 0.3,
    "severity": 0.1,
    "blockers": 0
  },
  "thresholds": {
    "aging_days": 90,
    "trending_comments": 10,
    "trending_days": 14,
    "popular_reactions": 5
  },
  "labelPriority": [
    "regression",
    "blocker",
    "popular",
    "aging",
    "trending"
  ],
  "maxLabelsPerIssue": 2,
  "severityLabels": {
    "critical": ["regression", "crash", "hang", "data-loss", "P0"],
    "high": ["bug", "P1"],
    "medium": ["performance", "feature proposal", "feature-proposal", "P2"],
    "low": ["documentation", "enhancement", "P3"]
  }
}
