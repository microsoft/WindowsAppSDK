<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net6.0;net10.0</TargetFrameworks>
    <RuntimeIdentifier>win10-$(Platform)</RuntimeIdentifier>
    <RuntimeIdentifier Condition="'$(Platform)'=='AnyCpu'" >win10-x86</RuntimeIdentifier>
    <IsPackable>false</IsPackable>
    <GenerateProjectSpecificOutputFolder>False</GenerateProjectSpecificOutputFolder>
    <Platforms>x86;x64;arm64</Platforms>
  </PropertyGroup>

  <!-- Fix output paths for multi-targeting -->
  <PropertyGroup>
    <OutputPath>$(BaseOutputPath)$(MSBuildProjectName)\$(TargetFramework)\</OutputPath>
    <IntermediateOutputPath>$(BaseIntermediateOutputPath)$(TargetFramework)\</IntermediateOutputPath>
  </PropertyGroup>

</Project>
