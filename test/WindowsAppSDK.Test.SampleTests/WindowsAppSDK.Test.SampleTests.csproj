<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(RepoRoot)\build\CsMultiTargetPaths.props" />

  <PropertyGroup>
    <TargetFrameworks>net6.0-windows10.0.18362;net10.0-windows10.0.18362.1</TargetFrameworks>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <Platforms>x86;x64;arm64</Platforms>
    
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <WindowsAppSdkSelfContained>true</WindowsAppSdkSelfContained>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWinRT" Version="$(MicrosoftWindowsCsWinRTv3PackageVersion)" Condition="$(TargetFramework.StartsWith('net10.0'))" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.4.0" />
    <PackageReference Include="Microsoft.Taef" Version="10.75.221207001" />
    <PackageReference Include="Microsoft.Windows.Apps.Test" Version="1.0.181205002" />
  </ItemGroup>

  <Target Name="CopyTestDefFiles" AfterTargets="AfterBuild">
    <Copy SkipUnchangedFiles="true" SourceFiles="SampleTest.testdef" DestinationFolder="$(OutDir)" />
  </Target>


</Project>
