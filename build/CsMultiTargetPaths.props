<!--
  Shared properties for multi-target C# projects.

  Import this file from any C# project that uses <TargetFrameworks> (plural).

  Problem:
  EnsureOutputLayout.props sets OutDir=$(BaseOutputPath), which causes the SDK's
  Microsoft.Common.CurrentVersion.targets to set OutDirWasSpecified=true. This prevents
  the SDK from syncing OutDir=$(OutputPath), so OutDir lacks the TFM that the SDK
  naturally appends to OutputPath for multi-target builds. The result is TargetPath
  without TFM, causing P2P resolution collisions between target frameworks.

  Fix:
  Clear OutDir and OutDirWasSpecified so the SDK sets OutDir=$(OutputPath) naturally.
  The SDK's TargetFrameworkInference appends TFM to OutputPath/IntermediateOutputPath
  (default behavior), and then Microsoft.Common.CurrentVersion.targets sets OutDir
  from OutputPath — giving us correct, TFM-specific output directories.
-->
<Project>
  <!--
    .NET 10 SDK defaults TargetRefPath to $(IntermediateOutputPath)ref\ instead of $(OutDir)ref\.
    CleanIntermediateFiles deletes the obj directory after Build, so reference assemblies must
    be in the output directory to survive for P2P resolution.
  -->
  <PropertyGroup>
    <ProduceReferenceAssemblyInOutDir>true</ProduceReferenceAssemblyInOutDir>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)' != ''">
    <!--
      Clear OutDir and OutDirWasSpecified so the SDK sets OutDir=$(OutputPath) during
      property evaluation. This ensures $(TargetPath) includes the TFM.

      Disable GenerateProjectSpecificOutputFolder since OutputPath already contains
      the project name, preventing the SDK from appending it a second time.
    -->
    <OutDir></OutDir>
    <OutDirWasSpecified></OutDirWasSpecified>
    <GenerateProjectSpecificOutputFolder>false</GenerateProjectSpecificOutputFolder>
  </PropertyGroup>
</Project>
