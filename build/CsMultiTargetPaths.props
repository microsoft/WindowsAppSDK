<!--
  Shared properties for multi-target C# projects.

  Fixes output path configuration so that:
  1. The .NET SDK does not double the TargetFramework in OutputPath/IntermediateOutputPath
     (EnsureOutputLayout.props already sets these paths, and the SDK would append TFM again).
  2. OutDir is synced with OutputPath so each TargetFramework gets a separate output directory,
     preventing race conditions where one TFM's DLL overwrites another's.

  Import this file from any C# project that uses <TargetFrameworks> (plural).

  How it works:
  EnsureOutputLayout.props sets OutDir=$(BaseOutputPath), which causes the SDK's
  Microsoft.Common.CurrentVersion.targets to set OutDirWasSpecified=true and later
  append $(ProjectName) via GenerateProjectSpecificOutputFolder. This results in
  OutDir = BaseOutputPath\ProjectName\ (without TFM), causing collisions between
  target frameworks and incorrect TargetPath for ProjectReference resolution.

  We fix this by:
  - Clearing OutDir and OutDirWasSpecified so the SDK sets OutDir=$(OutputPath)
  - Setting GenerateProjectSpecificOutputFolder=false since OutputPath already
    includes the project name
  - Disabling SDK auto-append of TFM since OutputPath already includes it
-->
<Project>
  <!-- Prevent the SDK from appending TargetFramework since we handle it explicitly below. -->
  <PropertyGroup>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendTargetFrameworkToIntermediateOutputPath>false</AppendTargetFrameworkToIntermediateOutputPath>
  </PropertyGroup>

  <!--
    .NET 10 SDK defaults TargetRefPath to $(IntermediateOutputPath)ref\ instead of $(OutDir)ref\.
    CleanIntermediateFiles deletes the obj directory after Build, so reference assemblies must
    be in the output directory to survive for P2P resolution.
  -->
  <PropertyGroup>
    <ProduceReferenceAssemblyInOutDir>true</ProduceReferenceAssemblyInOutDir>
  </PropertyGroup>

  <!-- Set output paths with TFM for inner builds (TargetFramework is set as a global property). -->
  <PropertyGroup Condition="'$(TargetFramework)' != ''">
    <OutputPath>$(BaseOutputPath)$(MSBuildProjectName)\$(TargetFramework)\</OutputPath>
    <IntermediateOutputPath>$(BaseIntermediateOutputPath)$(TargetFramework)\</IntermediateOutputPath>

    <!--
      Clear OutDir and OutDirWasSpecified so the SDK's Microsoft.Common.CurrentVersion.targets
      sets OutDir=$(OutputPath) during property evaluation. This ensures $(TargetPath) —
      which GetTargetPath returns for ProjectReference resolution — includes the TFM.

      Also disable GenerateProjectSpecificOutputFolder since OutputPath already contains
      the project name, preventing the SDK from appending it a second time.
    -->
    <OutDir></OutDir>
    <OutDirWasSpecified></OutDirWasSpecified>
    <GenerateProjectSpecificOutputFolder>false</GenerateProjectSpecificOutputFolder>
  </PropertyGroup>
</Project>
