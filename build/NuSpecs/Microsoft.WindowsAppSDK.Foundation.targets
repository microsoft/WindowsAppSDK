<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Bootstrapper and auto-initialization targets have moved to the Microsoft.WindowsAppSDK.Base package. -->

  <!-- When the Foundation component package is referenced without the aggregator meta-package
       (e.g. in Foundation pipeline sample builds), override SelfContained to false.
       Without the meta-package, there's no framework MSIX to extract DLLs from,
       so SelfContained would leave the app with missing runtime DLLs.
       This runs after Base.targets which may have defaulted SelfContained=true. -->
  <PropertyGroup Condition="'$(MicrosoftWindowsAppSDKPackageDir)' == '' and '$(_WindowsAppSDKSelfContainedSetByDefault)' == 'true'">
    <WindowsAppSDKSelfContained>false</WindowsAppSDKSelfContained>
    <_WindowsAppSDKSelfContainedSetByDefault>false</_WindowsAppSDKSelfContainedSetByDefault>
  </PropertyGroup>

</Project>
